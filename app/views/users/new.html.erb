<%= form_for(:item, url: { action: :create }, html: { method: :post }) do |f| %>
  <%= error_messages_for :item %>

  <fieldset>
    <%= f.label(:name, "Name") %>
    <%= f.text_field(:name) %>
  </fieldset>

  <fieldset>
    <%= f.label(:email, "Email") %>
    <%= f.email_field(:email) %>
  </fieldset>

  <%= f.submit("Create") %>
  <%= link_to("Back", action: :index) %>
<% end %>
