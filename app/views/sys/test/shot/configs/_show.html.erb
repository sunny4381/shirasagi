<dl class="see">
  <dt>Name</dt>
  <dd><%= @item.config_name %></dd>

  <dt>Seed</dt>
  <dd><%= br @item.seeds %></dd>

  <dt>Allow</dt>
  <dd><%= br @item.allows %></dd>

  <dt>Deny</dt>
  <dd><%= br @item.denies %></dd>

  <dt>Timeout</dt>
  <dd><%= @item.timeout %></dd>

  <dt>Max Count</dt>
  <dd><%= @item.max_count %></dd>

  <dt>Strip Query</dt>
  <dd><%= @item.label :strip_query_part %></dd>

  <dt>Window Size</dt>
  <dd><%= @item.label :window_size %></dd>

  <dt>Capture Size</dt>
  <dd><%= @item.capture_size %></dd>

  <dt>Image Quality</dt>
  <dd><%= @item.image_quality %> (0 is poor, 100 is beautiful)</dd>

  <dt>Basic 認証</dt>
  <dd><%= @item.basic_auth_user %></dd>

  <% @model::MAX_FORM_COUNT.times do |i| %>
    <% if @item.send("form#{i}_check_css_selector").present? %>
      <dt>Form <%= i + 1 %></dt>
      <dd></dd>

      <dt class="depth-2">Form CSS Selector</dt>
      <dd class="depth-2"><%= @item.send("form#{i}_check_css_selector") %></dd>

      <% @model::MAX_INPUT_COUNT.times do |j| %>
        <% if @item.send("form#{i}_input#{j}_css_selector").present? %>
          <dt class="depth-2">Input <%= j + 1 %></dt>
          <dd class="depth-2"></dd>

          <dt class="depth-3">CSS Selector</dt>
          <dd class="depth-3"><%= @item.send("form#{i}_input#{j}_css_selector") %></dd>

          <dt class="depth-3">Value</dt>
          <dd class="depth-3"><%= @item.send("form#{i}_input#{j}_value") %></dd>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</dl>
