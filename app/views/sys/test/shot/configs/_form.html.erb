<dl class="see">
  <dt>Name</dt>
  <dd><%= f.text_field :config_name %></dd>

  <dt>Seed</dt>
  <dd><%= f.text_area :seeds %></dd>

  <dt>Allow</dt>
  <dd><%= f.text_area :allows %></dd>

  <dt>Deny</dt>
  <dd><%= f.text_area :denies %></dd>

  <dt>Timeout</dt>
  <dd><%= f.number_field :timeout %></dd>

  <dt>Max Count</dt>
  <dd><%= f.number_field :max_count %> Leave blank for unlimited</dd>

  <dt>Strip Query</dt>
  <dd><%= f.select :strip_query_part, @item.strip_query_part_options %></dd>

  <dt>Window Size</dt>
  <dd><%= select_tag("item[in_window_size]", options_for_select(@item.window_size_options, @item.window_size)) %></dd>

  <% @model::MAX_FORM_COUNT.times do |i| %>
    <dt>Form <%= i + 1 %></dt>
    <dd></dd>

    <dt class="depth-2">Form CSS Selector</dt>
    <dd class="depth-2"><%= f.text_field "form#{i}_check_css_selector" %></dd>

    <% @model::MAX_INPUT_COUNT.times do |j| %>
      <dt class="depth-2">Input <%= j + 1 %></dt>
      <dd class="depth-2"></dd>

      <dt class="depth-3">CSS Selector</dt>
      <dd class="depth-3"><%= f.text_field "form#{i}_input#{j}_css_selector" %></dd>

      <dt class="depth-3">Value</dt>
      <dd class="depth-3"><%= f.text_field "form#{i}_input#{j}_value" %></dd>
    <% end %>
  <% end %>
</dl>
