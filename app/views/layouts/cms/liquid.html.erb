<%
  layout ||= @cur_layout
  template = Liquid::Template.parse(layout.html)
  # registers: variables are used in liquid classes like drops, tags, filters and so on
  template.registers['view_context'] = self
  template.registers['controller'] = controller
  template.registers['cur_site'] = @cur_site if @cur_site.present?
  template.registers['cur_node'] = @cur_node if @cur_node.present?
  template.registers['cur_page'] = @cur_page if @cur_page.present?
  template.registers['cur_part'] = @cur_part if @cur_part.present?
  template.registers['cur_item'] = @cur_item if @cur_item.present?
  # assings: variables are used in a liquid template
  template.assigns['cms'] = Cms::Liquid::BaseDrop.new
  template.assigns['site'] = proc { |context| context['cms'].cur_site }
  template.assigns['node'] = proc { |context| context['cms'].cur_node }
  template.assigns['page'] = proc { |context| context['cms'].cur_page }
  template.assigns['part'] = proc { |context| context['cms'].cur_part }
  template.assigns['item'] = proc { |context| context['cms'].cur_item }
  template.assigns['yield'] = proc do
    yield
  end
%>

<%== template.render %>
