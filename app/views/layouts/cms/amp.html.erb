<!doctype html>
<html ⚡>
<head>
  <meta charset="utf-8">
  <link rel="canonical" href="<%= @cur_path %>">
  <meta name="viewport" content="width=device-width,minimum-scale=1,initial-scale=1">
  <title><%= @window_name %></title>
  <style amp-boilerplate>body{-webkit-animation:-amp-start 8s steps(1,end) 0s 1 normal both;-moz-animation:-amp-start 8s steps(1,end) 0s 1 normal both;-ms-animation:-amp-start 8s steps(1,end) 0s 1 normal both;animation:-amp-start 8s steps(1,end) 0s 1 normal both}@-webkit-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@-moz-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@-ms-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@-o-keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}@keyframes -amp-start{from{visibility:hidden}to{visibility:visible}}</style>
  <noscript><style amp-boilerplate>body{-webkit-animation:none;-moz-animation:none;-ms-animation:none;animation:none}</style></noscript>
  <style amp-custom>
    body {
      font-family: Meiryo,"メイリオ",Tahoma,"Hiragino Kaku Gothic Pro","ヒラギノ角ゴ Pro W3",Verdana,"MS PGothic","ＭＳ　Ｐゴシック",sans-serif;
      color: #666;
      line-height: 1.85;
    }
    #page {
      font-size: 87.5%;
    }
    #tool {
      border-bottom: 3px solid #f08300;
    }
    #tool nav {
      position: relative;
      padding: 5px 10px;
    }
    #tool nav #nocssread {
      border-right: 1px solid #ccc;
      padding-left: 17px;
      padding-right: 10px;
      background: url(../img/u-arrow.png) no-repeat left center;
    }
    #tool nav #info {
      float: right;
      padding: 0 10px;
      border-left: 1px solid #ccc;
    }
    #tool nav #ss-kana {
      float: right;
      padding-left: 30px;
      padding-right: 10px;
      background: url(/img/kana.png) no-repeat 10px center;
      border-left: 1px solid #ccc;
    }
    #tool nav #ss-voice {
      float: right;
      padding-left: 30px;
      padding-right: 10px;
      background: url(/img/voice.png) no-repeat 10px center;
      border-left: 1px solid #ccc;
    }
    #tool nav #theme {
      float: right;
      padding: 0 10px;
      border-left: 1px solid #ccc;
    }
    #tool nav #size {
      float: right;
      border-left: 1px solid #ccc;
      padding: 0 10px;
    }
    #tool nav #size span {
      margin-left: 5px;
      padding: 3px;
      background: #cee;
      border-radius: 3px;
    }
    #head .logo {
      display: inline-block;
      padding: 17px 0;
    }
    #head .menu {
      float: right;
      margin-top: 10px;
    }
    #head .menu .u-menu .smart {
      padding-left: 15px;
      background: url(/img/smart.png) no-repeat left center;
    }
    #navi {
      background-image: linear-gradient(to bottom, #007acd,#0069cc);
      background:url(data:image/svg+xml;base64,);
      border-bottom: 3px solid #f08300;
    }
    #navi .wrap {
      border-left: 1px solid #005797;
      border-right: 1px solid #439bd5;
    }
    nav ul {
      list-style: none;
      -webkit-margin-before: 0;
      -webkit-margin-after: 0;
      -webkit-padding-start: 0;
    }
    #navi .wrap li {
      display: inline-block;
      width: 180px;
      border-left: 1px solid #439bd5;
      border-right: 1px solid #005797;
      font-size: 115%;
      padding: 5px 0 4px;
    }
    #navi .wrap a {
      color: #fff;
      vertical-align: middle;
      text-decoration: none;
      text-align: center;
      width: 100%;
    }
    #wrap {
      display: flex;
    }
    #main {
      flex: 1;
    }
    #side {
      width: 300px;
    }
  </style>
  <script async src="https://cdn.ampproject.org/v0.js"></script>
  <script async custom-element="amp-form" src="https://cdn.ampproject.org/v0/amp-form-0.1.js"></script>
  <script async custom-element="amp-social-share" src="https://cdn.ampproject.org/v0/amp-social-share-0.1.js"></script>
</head>

<%= yield %>

</html>
