<%= jquery do %>
  SS_SearchUI.modal();
  SS_TreeUI.render(".index.groups");
<% end %>

<div class="content-search card mb-3">
  <div class="card-body search-ui-form">
    <%= form_for :s, url: { action: :index }, html: { method: "GET", class: "search no-form-inline" } do |f| %>
      <%= hidden_field_tag :single, params[:single] %>
      <div class="input-group">
        <%= f.text_field :keyword, value: params[:s].try(:[], :keyword) %>
        <div class="input-group-append">
          <%= f.submit  t("ss.buttons.search"), class: :btn %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%= paginate @items if @items.try(:current_page) %>

<div class="table-responsive">
  <table class="table table-striped index groups">
    <thead class="list-head">
      <tr>
        <% if @multi %>
        <th class="checkbox"><input type="checkbox" /></th>
        <% end %>
        <th class="name"><%= t("ss.apis.organizations.label") %></th>
      </tr>
    </thead>
    <tbody class="items">
      <% @items.each do |item| %>
        <tr data-id="<%= item.id %>" class="list-item">
          <% if @multi %>
          <td class="checkbox">
            <input type="checkbox" name="ids[]" value="<%= item.id %>" />
          </td>
          <% end %>
          <td class="expandable">
            <%= link_to item.name, "#", class: @multi ? "select-item" : "select-single-item" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= paginate @items if @items.try(:current_page) %>

<% if @multi %>
<div class="search-ui-select">
  <%= button_tag t("ss.links.select"), { type: :button, class: "select-items btn" } %>
</div>
<% end %>
