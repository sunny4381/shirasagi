<%= jquery do %>
SS_SearchUI.modal();
SS.ajax("#ajax-box .select", {
  success: function (data) {
    var dataId = $('<div>' + data + '</div>').find("[data-id]").attr("data-id");
    if (dataId) {
      $("#selected-member-photos .file-view[data-id='" + dataId + "']").remove();
    }
    $("#selected-member-photos").append(data);
    $.colorbox.close();
  }
});
<% end %>

<div class="content-search card mb-3">
  <div class="card-body search-ui-form">
  <%= form_for :s, url: { action: :index }, html: { method: "GET", class: "search no-form-inline" } do |f| %>
    <div class="input-group">
      <%= f.text_field :name, value: params[:s].try(:[], :name) %>
      <div class="input-group-append">
        <%= f.submit t("member.links.search"), class: :btn %>
      </div>
    </div>
  <% end %>
  </div>
</div>

<% @items.each do |item| %>
  <article class="file-view member-photo">
    <a class="thumb select cboxElement" href="<%= select_member_apis_photo_path(id: item.id, site: @cur_site) %>">
      <%= image_tag item.image.thumb_url, alt: item.name %>
    </a>
    <div class="name">
      <%= item.name %>
    </div>
  </article>
<% end %>
