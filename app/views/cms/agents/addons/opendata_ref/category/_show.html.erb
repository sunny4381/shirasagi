<% return "" if @item.opendata_category_ids.blank? %>
<%
  addon ||= local_assigns.fetch(:addon, {})
  addon[:display_body] = "hide"
%>

<%= f.ss_field_set :opendata_category_ids, disabled: true do %>
  <div id="item_opendata_category_ids" class="table-responsive">
    <table class="table table-striped">
      <tbody>
      <% @item.opendata_categories.pluck(:name).each do |opendata_category_name| %>
      <tr>
        <td><%= opendata_category_name %></td>
      </tr>
      <% end %>
      </tbody>
    </table>
  </div>
<% end %>
