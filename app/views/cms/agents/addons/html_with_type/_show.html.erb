<% return if @item.html.blank? %>

<dl class="see mod-cms-html-with-type">
  <% html_type_label = @item.label :html_type %>
  <% if html_type_label.present? %>
  <dd class="wide"><%= html_type_label %></dd>
  <% end %>

  <dd class="wide">
    <%= code_editor "#mod-cms-html", mode: :html, readonly: true %>
    <%= text_area_tag "mod-cms-html", @item.html, style: "height: 400px" %>
  </dd>
</dl>
