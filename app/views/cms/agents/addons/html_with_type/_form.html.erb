<%= code_editor ".mod-cms-html-with-type textarea", mode: :html %>

<dl class="see mod-cms-html-with-type">
  <% options = @item.html_type_options %>
  <% if options.length > 1 %>
    <dd class="wide"><%= f.select :html_type, @item.html_type_options %></dd>
  <% else %>
    <%= f.hidden_field :html_type %>
  <% end %>
  <dd class="wide"><%= f.text_area :html, style: "height: 400px" %></dd>
</dl>
