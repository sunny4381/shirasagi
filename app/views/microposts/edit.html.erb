<%= form_for(:item, url: { action: :update }, html: { method: :put }) do |f| %>
  <%= error_messages_for :item %>

  <fieldset>
    <%= f.label(:content, "Content") %>
    <%= f.text_area(:content) %>
  </fieldset>

  <fieldset>
    <%= f.label(:user_id, "User Id") %>
    <%= f.number_field(:user_id) %>
  </fieldset>

  <%= f.submit("Save") %>
  <%= link_to("Back", action: :index) %>
<% end %>
