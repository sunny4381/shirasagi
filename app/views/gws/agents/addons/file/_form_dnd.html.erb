<dl class="see gws-addon-file">
  <dd class="wide">
    <%= f.hidden_field "file_ids[]", value: "" %>
    <span class="upload-menu-new">
      <%= button_tag(t('ss.links.upload'), name: 'file-upload-btn', type: :button, class: 'btn') %>
      <%= file_field_tag('file', id: nil, style: 'display: none;') %>
      <%# link_to t('ss.links.upload'), sns_apis_temp_files_path(@cur_user), class: "ajax-box btn" %>
    </span>
    <span class="upload-menu-select">
      <%= link_to t("sns.user_file"), sns_apis_user_files_path(@cur_user), class: "ajax-box btn" %>
      <%= link_to t("modules.gws/share"), gws_apis_files_path, class: "ajax-box btn" %>
    </span>

    <div class="dnd-files">
      <% @item.files.each do |file| %>
        <label for="<%= "#{f.object_name}_file_ids_#{file.id}" %>" class="dnd-file">
          <span class="cell selected">
            <%= check_box_tag("#{f.object_name}[file_ids][]", file.id, true, id: "#{f.object_name}_file_ids_#{file.id}") %>
          </span>
          <span class="cell icon">
            <% if file.image? %>
            <%= image_tag(file.thumb_url, alt: file.name) %>
            <% else %>
            <i class="material-icons">&#xE24D;</i><br>
            <span class="ext icon-<%= file.extname %>"><%= file.extname %></span>
            <% end %>
          </span>
          <span class="cell filename">
            <%= file.humanized_name %>
          </span>
          <span class="cell ctrl">
            <%= button_tag("編集", type: :button, name: 'edit', class: 'btn') %>
            <%= button_tag(type: :button, name: 'paste', class: 'btn') do %>貼り付け<i class="material-icons md-13"></i><% end %>
            <%= button_tag("削除", type: :button, name: 'delete', class: 'btn') %>
          </span>
        </label>
      <% end %>
      <% SS::TempFile.allow(:read, @cur_user).order_by(filename: 1).each do |file| %>
        <label for="<%= "#{f.object_name}_file_ids_#{file.id}" %>" class="dnd-file">
          <span class="cell selected">
            <%= check_box_tag("#{f.object_name}[file_ids][]", file.id, false, id: "#{f.object_name}_file_ids_#{file.id}") %>
          </span>
            <span class="cell icon">
            <% if file.image? %>
            <%= image_tag(file.thumb_url, alt: file.name) %>
            <% else %>
            <i class="material-icons">&#xE24D;</i><br>
            <span class="ext icon-<%= file.extname %>"><%= file.extname %></span>
            <% end %>
          </span>
          <span class="cell filename">
            <%= file.humanized_name %>
          </span>
          <span class="cell ctrl">
            <%= button_tag("編集", type: :button, name: 'edit', class: 'btn') %>
            <%= button_tag(type: :button, name: 'paste', class: 'btn') do %>貼り付け<i class="material-icons md-13"></i><% end %>
            <%= button_tag("削除", type: :button, name: 'delete', class: 'btn') %>
          </span>
        </label>
      <% end %>
    </div>

    <div id="modal-edit" style="display: none">
      <a href="#modal-edit-form"></a>

      <div id="modal-edit-form">
        <div class="addon-views">
          <div class="addon-view">
            <dl class="see">
              <dt>名前</dt>
              <dd><%= text_field_tag('name') %></dd>

              <dt>ファイル名</dt>
              <dd><%= text_field_tag('filename') %></dd>

              <dt><%= t('ss.resize_image') %></dt>
              <dd>
                <%= select_tag(:resizing, options_for_select(SS::File.resizing_options), include_blank: t('ss.resize_image')) %>
              </dd>
            </dl>
          </div>
        </div>
        <footer class="send">
          <%= button_tag(t('ss.buttons.save'), name: 'save', type: :button, class: 'btn-primary save') %>
          <%= button_tag(t('ss.buttons.cancel'), name: 'cancel', type: :reset, class: 'btn-default') %>
        </footer>
      </div>
    </div>
  </dd>
</dl>

<%= jquery do %>
  var dnd = new SS_FileDnd(
    '#addon-gws-agents-addons-file .addon-body',
    '<%= sns_apis_temp_files_path(user: @cur_user, format: :json) %>',
    '<%= meta_sns_apis_temp_files_path(user: @cur_user, format: :json) %>');
<% end %>
