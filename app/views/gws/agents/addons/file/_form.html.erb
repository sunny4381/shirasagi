<% return if @file_addon_state == 'hide' %>

<%
  def dnd_file_upload?
    brower = controller.send(:browser)
    return true if !browser.ie?
    browser.version.to_i >= 11
  end
%>

<% if dnd_file_upload? %>
  <%= render file: 'gws/agents/addons/file/_form_dnd', locals: { f: f } %>
<% else %>
  <%= render file: 'gws/agents/addons/file/_form_ie9', locals: { f: f } %>
<% end %>
