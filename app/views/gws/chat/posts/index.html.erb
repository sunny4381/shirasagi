<div class="index gws-chat-posts">
  <%= render file: '_list_head' %>

  <div class="posts">
    <% @items.each do |item| %>
    <div class="post <%= item.user == @cur_user ? 'mines' : 'theirs' %>" data-item-id="<%= item.id %>">
      <div class="row">
        <div class="aside">
          <%= render_avatar_image(item.user) %>
        </div>
        <div class="main">
          <div class="header">
            <span class="user"><%= item.user.long_name %></span>
            <span class="time"><%= item.updated.strftime('%Y/%m/%d %H:%M') %></span>
          </div>
          <div class="body"><%= br item.text %></div>
        </div>
      </div>
      <div class="row">
        <span>
          <button type="button" name="edit"><i class="material-icons md-13">&#xE254;</i></button>
          <button type="button" name="delete"><i class="material-icons md-13">&#xE872;</i></button>
        </span>
      </div>
    </div>
    <% end %>
  </div>

  <%= render 'post_form' %>
</div>

<%= jquery do %>
  var post = new Gws_Chat_Post('.gws-chat-posts', {
    createUrl: <%== url_for(action: :create).to_json %>,
    editUrl: <%== url_for(action: :edit, id: ':item_id').to_json %>,
    deleteUrl: <%== url_for(action: :delete, id: ':item_id').to_json %>
  });
  post.render();
<% end %>
