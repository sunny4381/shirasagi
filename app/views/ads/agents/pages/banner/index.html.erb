<!doctype html>
<html lang="<%= I18n.locale %>">
<head>
<meta charset="UTF-8" />
<% if @cur_page.link_url != '#' %>
<meta http-equiv="refresh" content="0; URL=<%= @cur_page.link_url %>">
<% end %>
<title><%= @cur_page.name %></title>
<%= Cms.canonical_full_url(@cur_site, request).try { tag.link(rel: "canonical", href: _1) } %>
</head>
<body>
  <%= @cur_page.name %><br />
  <%= link_to @cur_page.link_url, @cur_page.link_url %>
  <img src="<%= @cur_page.count_url %>" width="0" height="0" border="0" alt="" />
</body>
</html>
