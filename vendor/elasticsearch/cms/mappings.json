{
  "_default_": {
    "_all": {
      "enabled": false
    },
    "dynamic_templates": [
      {
        "categories": {
          "match": "cate_*",
          "mapping": { "type": "keyword" }
        }
      }
    ],
    "properties": {
      "id": { "type": "keyword" },
      "url": { "type": "string" },
      "name": { "type": "text", "analyzer": "cms_ja_analyzer", "copy_to": "text_index" },
      "html": { "type": "text", "analyzer": "cms_ja_analyzer", "copy_to": "text_index" },
      "released": { "type": "date", "format": "strict_date_optional_time||epoch_millis" },
      "member_permissions": { "type": "string" },
      "updated": { "type": "date", "format": "strict_date_optional_time||epoch_millis" },
      "created": { "type": "date", "format": "strict_date_optional_time||epoch_millis" },
      "text_index" : { "type": "text", "analyzer": "cms_ja_analyzer" },
      "data" : { "type": "text", "index" : "no", "store" : "no" },
      "file" : {
        "properties" : {
          "extname": { "type": "keyword" },
          "size": { "type": "integer" }
        }
      },
      "attachment": {
        "properties" : {
          "date" : { "type": "date", "format": "strict_date_optional_time||epoch_millis" },
          "content_type" : { "type": "keyword" },
          "author" : { "type": "text", "analyzer": "cms_ja_analyzer" },
          "language" : { "type": "keyword" },
          "title" : { "type": "text", "analyzer": "cms_ja_analyzer", "copy_to": "text_index" },
          "content" : { "type": "text", "analyzer": "cms_ja_analyzer", "copy_to": "text_index" },
          "content_length" : { "type": "integer" }
        }
      }
    }
  }
}
